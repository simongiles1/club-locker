# -----------------------------------------------------------------------------
# Copy this file to .env in THIS folder (apps/api/.env) and edit values there.
# The app loads apps/api/.env automatically. This file (.env.example) is NOT read at runtime.
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3001
DATABASE_URL=file:./data/squash.db
CLUB_LOCKER_ADAPTER=mock
EMAIL_ADAPTER=console
# Set EMAIL_ADAPTER=gmail to send championship/match emails through a Gmail account.
# Requirements (one-time setup on the Google account that will send the emails):
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      → choose "Mail" + a custom name like "Squash League". You'll get a 16-char password.
#   3. Paste the App Password into GMAIL_APP_PASSWORD below (no spaces required, but allowed).
# GMAIL_USER=club.director@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# GMAIL_FROM_NAME=Squash League Director
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
#
# Inbound AI agent (Gemini)
# AI_AGENT=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# AUTOMATION_TICK_INTERVAL_MS=60000
#
# Optional Langfuse tracing (leave blank to disable)
# LANGFUSE_HOST=http://localhost:3002
LANGFUSE_PUBLIC_KEY=pk-lf-d01686db-94d5-42ba-b75d-468179477295
LANGFUSE_SECRET_KEY=sk-lf-bf88ff39-f1f4-4f41-b948-745ad4529695

# US Squash / Club Locker (server-only; never expose to the web app)
#
# Members page: US_SQUASH_MODE=mock uses synthetic "Player N" rows.
# For real GET …/clubs/10706/members2 data, use live + secrets in .env (not in .env.example).
# US_SQUASH_MODE=mock
# US_SQUASH_MODE=live
# US_SQUASH_API_BASE=https://api.ussquash.com/resources/res
# US_SQUASH_BEARER_TOKEN=
# US_SQUASH_SESSION_COOKIE=USSQ-API-SESSION=s%3A...   (full Cookie value; no duplicate name prefix)
# US_SQUASH_CLUB_ID=10706
# Required for live season bulk + weekly conversion: set both from your club’s court list. If unset,
# the API falls back to built-in defaults (see apps/api/src/config.ts) which may not match your Center court.
# US_SQUASH_COURT_1_ID=3510
# US_SQUASH_COURT_2_ID=3511
# US_SQUASH_CUSTOM_MATCH_TYPE=457
# US_SQUASH_MEMBERS_PAGE_SIZE=500
# US_SQUASH_MEMBERS_MOCK_COUNT=564

# Optional Phase 2
# PLAYWRIGHT_CLUB_LOCKER_USER=
# PLAYWRIGHT_CLUB_LOCKER_PASS=
